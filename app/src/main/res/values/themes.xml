<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Project" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <!-- CalendarView Custom Styles -->
    <style name="CalendarViewCustom" parent="ThemeOverlay.MaterialComponents">
        <item name="colorPrimary">#003580</item>
        <item name="colorAccent">#003580</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="android:textColorPrimary">#1A1A1A</item>
        <item name="android:textColorSecondary">#1A1A1A</item>
        <item name="android:textColorTertiary">#1A1A1A</item>
        <item name="colorOnSurface">#003580</item>
    </style>

    <style name="CalendarDateCustom" parent="android:TextAppearance.DeviceDefault.Medium">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#1A1A1A</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="CalendarWeekCustom" parent="android:TextAppearance.DeviceDefault.Small">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#666666</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CalendarDateStyle" parent="Widget.AppCompat.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#000000</item>
    </style>

    <style name="CalendarWeekStyle" parent="Widget.AppCompat.Button">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#666666</item>
    </style>

    <style name="CalendarTheme" parent="ThemeOverlay.MaterialComponents">
        <item name="colorPrimary">#003580</item>
        <item name="colorAccent">#003580</item>
        <item name="android:textColorPrimary">#1A1A1A</item>
        <item name="android:textColorSecondary">#6B6B6B</item>
    </style>

    <style name="Theme.HotelBooking" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">#003580</item>
        <item name="colorPrimaryVariant">#002266</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#FEBB02</item>
        <item name="colorSecondaryVariant">#E5A800</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="android:statusBarColor">#002266</item>
    </style>

    <style name="Theme.Project" parent="Base.Theme.Project" />
</resources>