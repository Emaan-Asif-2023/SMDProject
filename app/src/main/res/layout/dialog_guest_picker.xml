<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:padding="24dp"
    android:minWidth="300dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Who's staying?"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:layout_marginBottom="24dp" />

    <!-- Adults Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="16dp"
        android:background="@drawable/guest_item_bg"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Adults"
                android:textSize="16sp"
                android:textColor="#1A1A1A"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ages 13+"
                android:textSize="13sp"
                android:textColor="#6B6B6B" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/buttonAdultMinus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="−"
                android:textSize="18sp"
                android:textColor="#003580"
                android:background="@drawable/counter_button_bg"
                android:padding="0dp"
                android:stateListAnimator="@null" />

            <TextView
                android:id="@+id/textViewAdultsCount"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="1"
                android:textSize="18sp"
                android:textColor="#1A1A1A"
                android:gravity="center"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonAdultPlus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="+"
                android:textSize="18sp"
                android:textColor="#003580"
                android:background="@drawable/counter_button_bg"
                android:padding="0dp"
                android:stateListAnimator="@null" />

        </LinearLayout>

    </LinearLayout>

    <!-- Children Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="16dp"
        android:background="@drawable/guest_item_bg"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Children"
                android:textSize="16sp"
                android:textColor="#1A1A1A"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ages 0-12"
                android:textSize="13sp"
                android:textColor="#6B6B6B" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/buttonChildMinus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="−"
                android:textSize="18sp"
                android:textColor="#003580"
                android:background="@drawable/counter_button_bg"
                android:padding="0dp"
                android:stateListAnimator="@null" />

            <TextView
                android:id="@+id/textViewChildrenCount"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="18sp"
                android:textColor="#1A1A1A"
                android:gravity="center"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonChildPlus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="+"
                android:textSize="18sp"
                android:textColor="#003580"
                android:background="@drawable/counter_button_bg"
                android:padding="0dp"
                android:stateListAnimator="@null" />

        </LinearLayout>

    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/buttonCancel"
            android:layout_width="100dp"
            android:layout_height="48dp"
            android:text="Cancel"
            android:textColor="#6B6B6B"
            android:textSize="14sp"
            android:background="@drawable/button_cancel_bg"
            android:layout_marginEnd="12dp"
            android:textAllCaps="false"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/buttonConfirm"
            android:layout_width="100dp"
            android:layout_height="48dp"
            android:text="Apply"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/button_primary_bg"
            android:textAllCaps="false"
            android:stateListAnimator="@null" />

    </LinearLayout>

</LinearLayout>